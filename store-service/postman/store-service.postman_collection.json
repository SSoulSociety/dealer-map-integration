{
  "info": {
    "name": "store-service",
    "description": "store-service endpoints aligned with API contract (Days 4-9)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/actuator/health"
      }
    },
    {
      "name": "Get All Stores",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/stores"
      }
    },
    {
      "name": "Get Stores By Ids",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/stores?ids=1,5,9"
      }
    },
    {
      "name": "Get Stores By Region",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/stores?city=Istanbul&district=Kadikoy"
      }
    },
    {
      "name": "Get Store By Id",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/stores/1"
      }
    },
    {
      "name": "Get Store By Id - Not Found",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/stores/999"
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8081" }
  ]
}
